rule bwa_index:
    input:
        fa=pjoin(WD, "{chrom}", "reference.fa"),
    output:
        pjoin(WD, "{chrom}", "reference.fa.sa"),
    log:
        pjoin(WD, "benchmark", "{chrom}", "bwa_index.time"),
    conda:
        "./envs/bwa.yaml"
    shell:
        """
        /usr/bin/time -vo {log} bwa index {input.fa}
        """


rule bwa_mem:
    input:
        fa=pjoin(WD, "{chrom}", "reference.fa"),
        sa=pjoin(WD, "{chrom}", "reference.fa.sa"),
        fq1=pjoin(WD, "{chrom}", "reads_R1.fastq"),
        fq2=pjoin(WD, "{chrom}", "reads_R2.fastq"),
    output:
        bam=pjoin(WD, "{chrom}", "alignments.bam"),
    log:
        pjoin(WD, "benchmark", "{chrom}", "bwa_mem.time"),
    conda:
        "./envs/bwa.yaml"
    threads: workflow.cores
    shell:
        """
        /usr/bin/time -vo {log} bwa mem -t{threads} {input.fa} {input.fq1} {input.fq2} | samtools view -bS | samtools sort > {output.bam}
        samtools index {output.bam}
        """
