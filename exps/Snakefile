rule vg_index:
    input:
        gfa=pjoin(WD, "{chrom}", "n{n}", "pangenome-{graph}.gfa"),
    output:
        gbz=pjoin(WD, "{chrom}", "n{n}", "pangenome-{graph}.giraffe.gbz"),
        mn=pjoin(WD, "{chrom}", "n{n}", "pangenome-{graph}.shortread.withzip.min"),
        zc=pjoin(WD, "{chrom}", "n{n}", "pangenome-{graph}.shortread.zipcodes"),
        dist=pjoin(WD, "{chrom}", "n{n}", "pangenome-{graph}.dist"),
    threads: workflow.cores
    params:
        prefix=pjoin(WD, "{chrom}", "n{n}", "pangenome-{graph}"),
    log:
        pjoin(WD, "benchmark", "{chrom}", "n{n}", "vg-index.{graph}.time"),
    shell:
        """
        /usr/bin/time -vo {log} vg autoindex --no-guessing --workflow sr-giraffe --gfa {input.gfa} --prefix {params.prefix} --threads {threads}
        """


rule vg_giraffe_nosampling:
    input:
        fq1=pjoin(WD, "{chrom}", "reads_R1.fastq"),
        fq2=pjoin(WD, "{chrom}", "reads_R2.fastq"),
        #
        gbz=pjoin(WD, "{chrom}", "n{n}", "pangenome-{graph}.giraffe.gbz"),
        mn=pjoin(WD, "{chrom}", "n{n}", "pangenome-{graph}.shortread.withzip.min"),
        zc=pjoin(WD, "{chrom}", "n{n}", "pangenome-{graph}.shortread.zipcodes"),
        dist=pjoin(WD, "{chrom}", "n{n}", "pangenome-{graph}.dist"),
    output:
        gam=pjoin(WD, "{chrom}", "n{n}", "giraffe-{graph}.gam"),
    threads: workflow.cores
    log:
        pjoin(WD, "benchmark", "{chrom}", "n{n}", "vg-giraffe.{graph}.time"),
    shell:
        """
        /usr/bin/time -vo {log} vg giraffe --gbz-name {input.gbz} --minimizer-name {input.mn} --zipcode-name {input.zc} --dist-name {input.dist} --progress --threads {threads} --output-format gam --fastq-in {input.fq1} --fastq-in {input.fq2} > {output.gam}
        """


