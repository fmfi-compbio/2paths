rule vg_rindex:
    input:
        gbz=pjoin(WD, "{chrom}", "n{n}", "pangenome-oneout.giraffe.gbz"),
    output:
        ri=pjoin(WD, "{chrom}", "n{n}", "pangenome-oneout.giraffe.ri"),
    threads: workflow.cores
    log:
        pjoin(WD, "benchmark", "{chrom}", "n{n}", "vg-rindex.oneout.time"),
    shell:
        """
        /usr/bin/time -vo {log} vg gbwt -p --num-threads {threads} -r {output.ri} -Z {input.gbz}
        """


rule haplotypes:
    input:
        gbz=pjoin(WD, "{chrom}", "n{n}", "pangenome-oneout.giraffe.gbz"),
        ri=pjoin(WD, "{chrom}", "n{n}", "pangenome-oneout.giraffe.ri"),
        dist=pjoin(WD, "{chrom}", "n{n}", "pangenome-oneout.dist"),
    output:
        hapl=pjoin(WD, "{chrom}", "n{n}", "pangenome-oneout.hapl"),
    threads: workflow.cores
    log:
        pjoin(WD, "benchmark", "{chrom}", "n{n}", "vg-haplotypes.oneout.time"),
    shell:
        """
        /usr/bin/time -vo {log} vg haplotypes -t {threads} -d {input.dist} -r {input.ri} -H {output.hapl} {input.gbz}
        """


rule kmc2kff:
    input:
        pre=pjoin(WD, "{chrom}", "reads.kmc_pre"),
        suf=pjoin(WD, "{chrom}", "reads.kmc_suf"),
    output:
        kff=pjoin(WD, "{chrom}", "reads.kff"),
    params:
        prefix=pjoin(WD, "{chrom}", "reads"),
    threads: workflow.cores
    log:
        pjoin(WD, "benchmark", "{chrom}", "kmc2kff.time"),
    conda:
        "./envs/kmc.yaml"
    shell:
        """
        /usr/bin/time -vo {log} kmc_tools -t{threads} transform {params.prefix} sort {params.prefix} -okff
        """


rule vg_sample_graph:
    input:
        gbz=pjoin(WD, "{chrom}", "n{n}", "pangenome-oneout.giraffe.gbz"),
        hapl=pjoin(WD, "{chrom}", "n{n}", "pangenome-oneout.hapl"),
        kff=pjoin(WD, "{chrom}", "reads.kff"),
    output:
        gbz=pjoin(WD, "{chrom}", "n{n}", "pangenome-sampled.gbz"),
    threads: workflow.cores
    log:
        pjoin(WD, "benchmark", "{chrom}", "n{n}", "vg-sampling.oneout.time"),
    shell:
        """
        /usr/bin/time -vo {log} vg haplotypes -t {threads} --include-reference --diploid-sampling -i {input.hapl} -k {input.kff} -g {output.gbz} {input.gbz}
        """


rule vg_giraffe_sampling:
    input:
        fq1=pjoin(WD, "{chrom}", "reads_R1.fastq"),
        fq2=pjoin(WD, "{chrom}", "reads_R2.fastq"),
        #
        gbz=pjoin(WD, "{chrom}", "n{n}", "pangenome-sampled.gbz"),
    output:
        gam=pjoin(WD, "{chrom}", "n{n}", "giraffe-sampled.gam"),
    threads: workflow.cores
    log:
        pjoin(WD, "benchmark", "{chrom}", "n{n}", "vg-giraffe.sampled.time"),
    shell:
        """
        /usr/bin/time -vo {log} vg giraffe -t{threads} -p --gbz-name {input.gbz} --fastq-in {input.fq1} --fastq-in {input.fq2} --output-format gam > {output.gam}
        """


